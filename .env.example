# ---------------------------------------------------------------------------
# MineABitcoin — Deployment Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: 12 or 24-word BIP-39 seed phrase of the deployer wallet
DEPLOYER_MNEMONIC="word1 word2 word3 ..."

# Optional: override the on-chain contract name (default: MineABitcoinBetaV01)
# CONTRACT_NAME=MineABitcoinBetaV01

# Optional: override the Stacks API endpoint
# Testnet default : https://api.testnet.hiro.so
# Mainnet default : https://api.hiro.so
# STACKS_API_URL=https://api.testnet.hiro.so
