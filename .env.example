# ---------------------------------------------------------------------------
# MineABitcoin — Deployment Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Clarinet deployment (recommended)
# ---------------------------------------------------------------------------
# The deployment plans in deployments/ are pre-filled with your STX address.
#
# clarinet deployments apply does NOT read a seed phrase. It needs your raw
# private key (hex). Derive it from your mnemonic once, then set it here:
#
#   STACKS_PRIVATE_KEY=<your-hex-private-key>
#
# Then deploy:
#   STACKS_PRIVATE_KEY=... clarinet deployments apply --testnet
#   STACKS_PRIVATE_KEY=... clarinet deployments apply --mainnet
#
# To get your hex private key from your seed phrase you can use the Stacks
# wallet SDK (one-time):
#   node -e "
#     const { generateWallet, getStxAddress } = require('@stacks/wallet-sdk');
#     generateWallet({ secretKey: 'your 24 words', password: '' })
#       .then(w => console.log('privkey:', w.accounts[0].stxPrivateKey));
#   "
STACKS_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Legacy TypeScript deploy script (scripts/deploy.ts)
# ---------------------------------------------------------------------------
# This script accepts your seed phrase directly and derives the key itself.
# Usage: npx tsx scripts/deploy.ts [testnet|mainnet]

# Required: 12 or 24-word BIP-39 seed phrase of the deployer wallet
DEPLOYER_MNEMONIC="word1 word2 word3 ..."

# Optional: override the on-chain contract name (default: MineABitcoinBetaV01)
# CONTRACT_NAME=MineABitcoin

# Optional: override the Stacks API endpoint
# Testnet default : https://api.testnet.hiro.so
# Mainnet default : https://api.hiro.so
# STACKS_API_URL=https://api.testnet.hiro.so
